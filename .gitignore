/target
/node_modules/
/.tmp/
/.tmp-disc/
/rom-weaver-out/
/rom-weaver/
.claude/
**/__pycache__/

# Local code-graph indexes (MCP servers)
/.codegraph/
/.tokensave/
/dist/

# Generated wasm artifacts
/dist/wasm/
/packages/rom-weaver-cli-platforms/*/bin/
/packages/rom-weaver-cli-platforms/*/LICENSE.md
/packages/rom-weaver-cli-platforms/*/NOTICE
/packages/rom-weaver-cli-platforms/*/THIRD_PARTY_LICENSES.md
/packages/rom-weaver-cli-platforms/*/third_party/

# Coverage reports
/dist/coverage/
/packages/rom-weaver-webapp/src/wasm/rom-weaver-app.wasm
/packages/rom-weaver-webapp/src/wasm/rom-weaver-app.wasm.br
/packages/rom-weaver-webapp/src/wasm/rom-weaver-app-threaded.wasm
/packages/rom-weaver-webapp/src/wasm/rom-weaver-app-threaded.wasm.br
/packages/rom-weaver-webapp/tests/wasm/__screenshots__/
