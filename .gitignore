/target
/node_modules/
/.tmp/
/.tmp-disc/
/rom-weaver-out/
/rom-weaver/
.claude/
**/__pycache__/

# Local code-graph indexes (MCP servers)
/.codegraph/
/.tokensave/
/dist/

# Generated CLI man pages (produced from Clap definitions via `mise run manpages`)
/docs/man/

# Generated wasm artifacts
/dist/wasm/
/packages/rom-weaver-cli-platforms/*/bin/
/packages/rom-weaver-cli-platforms/*/LICENSE.md
/packages/rom-weaver-cli-platforms/*/NOTICE
/packages/rom-weaver-cli-platforms/*/THIRD_PARTY_LICENSES.md
/packages/rom-weaver-cli-platforms/*/third_party/

# Coverage reports
/dist/coverage/
# Generated @rom-weaver/wasm package artifacts (wasm binary + bundled dist + attribution)
/packages/rom-weaver-wasm/dist/
/packages/rom-weaver-wasm/src/rom-weaver-app.wasm
/packages/rom-weaver-wasm/src/rom-weaver-app.wasm.br
/packages/rom-weaver-wasm/src/rom-weaver-app-threaded.wasm
/packages/rom-weaver-wasm/src/rom-weaver-app-threaded.wasm.br
/packages/rom-weaver-wasm/src/rom-weaver-app.wasm.prod.sha256
/packages/rom-weaver-wasm/src/NOTICE
/packages/rom-weaver-wasm/src/THIRD_PARTY_LICENSES.md
/packages/rom-weaver-wasm/src/third_party/
/packages/rom-weaver-webapp/tests/wasm/__screenshots__/

# Prebuilt artifacts staged for a `--build-arg BINARY=prebuilt` / `DIST=prebuilt`
# container build. CI writes this in the runner checkout; see docs/ci.md.
/prebuilt/
