{
  "name": "rom-weaver-quality-hooks",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "lefthook install",
    "hooks:install": "lefthook install",
    "hooks:run": "lefthook run pre-commit --force",
    "hooks:validate": "lefthook validate",
    "typegen": "cargo run -p rom-weaver-typegen -- --write",
    "typegen:check": "cargo run -p rom-weaver-typegen -- --check"
  },
  "devDependencies": {
    "knip": "6.16.1",
    "lefthook": "2.1.8"
  }
}
