{
  "name": "@rom-weaver/cli",
  "version": "0.7.0",
  "author": "Brandon Casey",
  "license": "AGPL-3.0-or-later",
  "description": "Local-first toolkit for ROMs and disc images: inspect, extract, compress, and apply, create, or bundle patches. Offline via a browser service-worker PWA or CLI.",
  "keywords": [
    "rom",
    "rom-hack",
    "patch",
    "ips",
    "bps",
    "chd",
    "rvz",
    "z3ds",
    "disc-image",
    "cli"
  ],
  "homepage": "https://rom-weaver.com",
  "funding": "https://ko-fi.com/brandonocasey",
  "repository": {
    "type": "git",
    "url": "https://github.com/brandonocasey/rom-weaver.git"
  },
  "type": "module",
  "bin": {
    "rom-weaver": "bin/rom-weaver.mjs"
  },
  "man": [
    "docs/man/rom-weaver.1",
    "docs/man/rom-weaver-probe.1",
    "docs/man/rom-weaver-extract.1",
    "docs/man/rom-weaver-checksum.1",
    "docs/man/rom-weaver-ingest.1",
    "docs/man/rom-weaver-compress.1",
    "docs/man/rom-weaver-trim.1",
    "docs/man/rom-weaver-patch.1",
    "docs/man/rom-weaver-patch-apply.1",
    "docs/man/rom-weaver-patch-create.1",
    "docs/man/rom-weaver-patch-validate.1",
    "docs/man/rom-weaver-bundle.1",
    "docs/man/rom-weaver-bundle-create.1",
    "docs/man/rom-weaver-bundle-parse.1",
    "docs/man/rom-weaver-bundle-schema.1",
    "docs/man/rom-weaver-tools.1",
    "docs/man/rom-weaver-tools-ppf-undo.1",
    "docs/man/rom-weaver-weave.1",
    "docs/man/rom-weaver-completions.1"
  ],
  "files": [
    "bin/rom-weaver.mjs",
    "docs/man/*.1",
    "LICENSE.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=22"
  },
  "optionalDependencies": {
    "@rom-weaver/darwin-arm64": "0.7.0",
    "@rom-weaver/darwin-x64": "0.7.0",
    "@rom-weaver/linux-x64-gnu": "0.7.0",
    "@rom-weaver/win32-x64-msvc": "0.7.0"
  },
  "scripts": {
    "docs:toc": "bash scripts/update-markdown-toc.sh",
    "dev": "mise run dev",
    "preview": "mise run preview",
    "hooks:install": "lefthook install",
    "hooks:run": "lefthook run pre-commit --force",
    "hooks:validate": "lefthook validate",
    "prepack": "mise run manpages",
    "test": "node --test scripts/*.test.mjs scripts/ci/*.test.mjs scripts/wasm/*.test.mjs",
    "audit:deps": "npm audit --audit-level=high",
    "typegen": "mise run typegen",
    "typegen:check": "mise run typegen-check",
    "version": "node scripts/sync-version.mjs"
  },
  "devDependencies": {
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "cross-spawn": "7.0.6",
    "doctoc": "2.5.0",
    "lefthook": "2.1.10"
  }
}
