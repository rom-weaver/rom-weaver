{
  "name": "rom-weaver",
  "version": "0.5.0",
  "author": "Brandon O'Casey",
  "license": "AGPL-3.0-or-later",
  "description": "A local-first toolkit for inspecting, patching, transforming, and preserving video game ROMs and disc images—in your browser or terminal.",
  "homepage": "https://rom-weaver.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/brandonocasey/rom-weaver.git"
  },
  "type": "module",
  "bin": {
    "rom-weaver": "bin/rom-weaver.mjs"
  },
  "files": [
    "bin/rom-weaver.mjs",
    "LICENSE.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=22"
  },
  "optionalDependencies": {
    "@brandonocasey/rom-weaver-darwin-arm64": "0.5.0",
    "@brandonocasey/rom-weaver-darwin-x64": "0.5.0",
    "@brandonocasey/rom-weaver-linux-x64-gnu": "0.5.0",
    "@brandonocasey/rom-weaver-win32-x64-msvc": "0.5.0"
  },
  "scripts": {
    "dev": "mise run dev",
    "preview": "mise run preview",
    "hooks:install": "lefthook install",
    "hooks:run": "lefthook run pre-commit --force",
    "hooks:validate": "lefthook validate",
    "test": "node --test scripts/check-conventional-commits.test.mjs scripts/wasm/*.test.mjs",
    "typegen": "mise run typegen",
    "typegen:check": "mise run typegen-check",
    "version": "node scripts/sync-version.mjs"
  },
  "devDependencies": {
    "lefthook": "2.1.8"
  }
}
