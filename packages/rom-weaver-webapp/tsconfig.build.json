{
  // Emit-only config for the published library type declarations, mirroring the
  // @rom-weaver/wasm package: `tsconfig.json` keeps `noEmit` for the
  // `lint:types` check; scripts/build-lib.mjs runs this one and then rewrites
  // the `.ts`/`.tsx` import specifiers in the emitted declarations to `.js` so
  // consumers without `allowImportingTsExtensions` resolve them.
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "dist/lib",
    "rootDir": "src"
  },
  // Only the library entry (plus ambient declarations, which no import pulls
  // in): tsc emits declarations for the entry's transitive graph, keeping
  // app-only modules (vite entry, service worker, ...) out of the published
  // tarball.
  "include": ["src/index.tsx", "src/**/*.d.ts"]
}
