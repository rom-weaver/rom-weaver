{
  "name": "@rom-weaver/webapp",
  "version": "0.6.1",
  "description": "A local-first offline toolkit for ROMs and ROM hack patches. Inspect, extract, checksum, compress, trim, apply patches, create patches, or bundle shareable patch manifests at native speed. In your browser or terminal.",
  "author": "Brandon Casey",
  "homepage": "https://rom-weaver.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/brandonocasey/rom-weaver.git"
  },
  "type": "module",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "types": "./src/index.tsx",
      "import": "./src/index.tsx"
    },
    "./webapp": "./src/webapp/main.tsx"
  },
  "overrides": {
    "vite-plugin-pwa": {
      "vite": "$vite"
    }
  },
  "scripts": {
    "audit:deps": "npm audit --audit-level=high",
    "audit:strings": "if rg --hidden --glob '!node_modules/**' --glob '!.git/**' --glob '!dist/**' 'rom-patcher' src tests index.html; then echo 'Found legacy rom-patcher identifiers' && exit 1; else echo 'No legacy rom-patcher identifiers found'; fi",
    "build": "vite build",
    "dev": "node scripts/ensure-wasm-build.mjs && node scripts/dev-server.mjs",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "i18n:compile": "lingui compile --typescript --output-prefix \"\"",
    "i18n:extract": "lingui extract",
    "icons:channels": "node scripts/generate-channel-icons.mjs",
    "icons:channels:check": "node scripts/generate-channel-icons.mjs --check",
    "lint": "run-s lint:i18n lint:checks",
    "lint:browser-compat": "node scripts/check-browser-compat.mjs",
    "lint:checks": "run-p --continue-on-error --aggregate-output format:check lint:code lint:types lint:browser-compat lint:knip lint:jscpd audit:strings",
    "lint:code": "run-s lint:code:oxlint lint:code:biome",
    "lint:code:biome": "biome lint . --diagnostic-level=error",
    "lint:code:oxlint": "oxlint . --deny-warnings",
    "lint:i18n": "lingui compile --strict --typescript --output-prefix \"\"",
    "lint:jscpd": "jscpd",
    "lint:knip": "knip --no-progress",
    "lint:types": "tsc -p tsconfig.json --noEmit",
    "prepare:dist": "node ./scripts/sync-dist.mjs",
    "preview": "node scripts/ensure-preview-build.mjs && node scripts/dev-server.mjs preview",
    "test": "npm run test:browser:parallel",
    "test:browser": "node scripts/run-browser-tests.mjs",
    "test:browser:chromium": "ROM_WEAVER_BROWSER=chromium node scripts/run-browser-tests.mjs",
    "test:browser:coverage": "ROM_WEAVER_COVERAGE=1 node scripts/run-browser-tests.mjs",
    "test:browser:parallel": "node scripts/run-browser-tests.mjs",
    "test:browser:wasm": "vitest --config ./vitest.wasm.browser.config.mjs run",
    "test:browser:wasm:bench": "ROM_WEAVER_WASM_BENCH=1 vitest --config ./vitest.wasm.browser.config.mjs bench",
    "test:browser:wasm:bench:checksum-threading": "ROM_WEAVER_WASM_BENCH=1 vitest --config ./vitest.wasm.browser.config.mjs bench tests/wasm/browser-checksum-threading.bench.mjs",
    "test:browser:wasm:bench:command-paths": "ROM_WEAVER_WASM_BENCH=1 vitest --config ./vitest.wasm.browser.config.mjs bench tests/wasm/browser-worker-client.bench.mjs",
    "test:browser:wasm:coverage": "ROM_WEAVER_COVERAGE=1 vitest --config ./vitest.wasm.browser.config.mjs run --coverage",
    "test:browser:wasm:exhaustive": "ROM_WEAVER_WASM_EXHAUSTIVE=1 vitest --config ./vitest.wasm.browser.config.mjs run -t \"exhaustive matrix\"",
    "test:browser:wasm:stress:1gb": "ROM_WEAVER_WASM_STRESS_1GB=1 vitest --config ./vitest.wasm.browser.config.mjs run -t \"survives 1 GiB compress extract checksum and 100MB-class xdelta apply workload\"",
    "test:browser:webkit": "ROM_WEAVER_BROWSER=webkit node scripts/run-browser-tests.mjs",
    "test:browser:webkit:smoke": "ROM_WEAVER_BROWSER=webkit vitest --config ./vitest.browser.config.mjs run tests/browser/mobile-safari-runtime-smoke.browser.test.js",
    "test:e2e:a11y": "node scripts/run-webapp-e2e.mjs --a11y",
    "test:e2e:fast": "node scripts/run-e2e.mjs fast",
    "test:e2e:ios": "node scripts/start-ios-e2e.mjs",
    "test:e2e:nightly": "node scripts/run-e2e.mjs nightly",
    "test:e2e:webapp": "node scripts/run-webapp-e2e.mjs",
    "test:e2e:webapp:webkit": "ROM_WEAVER_BROWSER=webkit node scripts/run-webapp-e2e.mjs",
    "test:unit": "vitest --config ./vitest.unit.config.mjs run",
    "test:unit:coverage": "ROM_WEAVER_COVERAGE=1 vitest --config ./vitest.unit.config.mjs run --coverage",
    "verify:sw:no-coop-coep": "node scripts/verify-service-worker-no-coop-coep.mjs"
  },
  "dependencies": {
    "@bjorn3/browser_wasi_shim": "0.4.2",
    "@lingui/core": "6.5.0",
    "lucide-react": "1.25.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "valibot": "1.4.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@lingui/babel-plugin-lingui-macro": "6.5.0",
    "@lingui/cli": "6.5.0",
    "@lingui/conf": "6.5.0",
    "@lingui/format-po": "6.5.0",
    "@mdn/browser-compat-data": "8.0.7",
    "@testing-library/react": "16.3.2",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/browser": "4.1.10",
    "@vitest/browser-playwright": "4.1.10",
    "@vitest/coverage-v8": "4.1.10",
    "axe-core": "4.12.1",
    "browserslist": "4.28.6",
    "happy-dom": "20.11.0",
    "jscpd": "5.0.12",
    "knip": "6.27.0",
    "npm-run-all2": "9.0.2",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "playwright": "1.61.1",
    "typescript": "^7.0.2",
    "vite": "8.1.5",
    "vite-plugin-pwa": "1.3.0",
    "vitest": "4.1.10",
    "workbox-core": "7.4.1",
    "workbox-precaching": "7.4.1",
    "workbox-routing": "7.4.1"
  },
  "browserslist": [
    "last 2 Chrome major versions",
    "last 2 Edge major versions",
    "last 2 Firefox major versions",
    "last 2 Safari major versions",
    "last 2 iOS major versions"
  ]
}
