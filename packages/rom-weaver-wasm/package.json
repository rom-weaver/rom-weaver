{
  "name": "@rom-weaver/wasm",
  "version": "0.7.1",
  "description": "Browser WebAssembly runtime for rom-weaver: a WASI + OPFS threaded worker engine to inspect, extract, compress, and patch ROMs and disc images.",
  "keywords": [
    "rom",
    "wasm",
    "webassembly",
    "wasi",
    "opfs",
    "chd",
    "rvz",
    "z3ds",
    "disc-image",
    "patch"
  ],
  "author": "Brandon Casey",
  "homepage": "https://rom-weaver.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/brandonocasey/rom-weaver.git",
    "directory": "packages/rom-weaver-wasm"
  },
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json",
    "./rom-weaver-types": {
      "types": "./dist/rom-weaver-types.d.ts"
    },
    "./generated/rom-weaver-rust-types": {
      "types": "./dist/generated/rom-weaver-rust-types.d.ts"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    }
  },
  "files": [
    "dist",
    "src/**/*.ts",
    "src/**/*.d.ts"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "run-s lint:types lint:code lint:knip format:check",
    "lint:code": "run-s lint:code:oxlint lint:code:biome",
    "lint:code:biome": "biome lint . --diagnostic-level=error",
    "lint:code:oxlint": "oxlint . --deny-warnings",
    "lint:knip": "knip --no-progress",
    "lint:types": "tsc -p tsconfig.json --noEmit",
    "prepack": "node scripts/build.mjs",
    "prepare": "node scripts/build.mjs"
  },
  "dependencies": {
    "@bjorn3/browser_wasi_shim": "0.4.2"
  },
  "devDependencies": {
    "esbuild": "0.25.12",
    "typescript": "^7.0.2"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
