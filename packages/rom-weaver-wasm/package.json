{
  "name": "rom-weaver-wasm",
  "version": "0.1.0",
  "description": "JavaScript APIs and WASM artifacts for rom-weaver",
  "type": "module",
  "types": "./src/index.d.ts",
  "license": "MIT OR Apache-2.0",
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "files": [
    "src/",
    "rom-weaver-cli.wasm",
    "rom-weaver-cli.wasm.br",
    "rom-weaver-cli-threaded.wasm",
    "rom-weaver-cli-threaded.wasm.br",
    "threaded.args",
    "README.md",
    "NOTICE",
    "THIRD_PARTY_LICENSES.md"
  ],
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.mjs"
    },
    "./zenfs": {
      "types": "./src/rom-weaver-zenfs-api.d.ts",
      "import": "./src/rom-weaver-zenfs-api.mjs"
    },
    "./workers/browser-client": {
      "types": "./src/workers/browser-worker-client.d.ts",
      "import": "./src/workers/browser-worker-client.mjs"
    },
    "./workers/protocol": {
      "types": "./src/workers/worker-protocol.d.ts",
      "import": "./src/workers/worker-protocol.mjs"
    },
    "./workers/browser-runner-worker": {
      "types": "./src/workers/browser-runner-worker.d.ts",
      "import": "./src/workers/browser-runner-worker.mjs"
    },
    "./rom-weaver-cli.wasm": "./rom-weaver-cli.wasm",
    "./rom-weaver-cli.wasm.br": "./rom-weaver-cli.wasm.br",
    "./rom-weaver-cli-threaded.wasm": "./rom-weaver-cli-threaded.wasm",
    "./rom-weaver-cli-threaded.wasm.br": "./rom-weaver-cli-threaded.wasm.br",
    "./threaded.args": "./threaded.args"
  },
  "scripts": {
    "prepare:dist": "node ./scripts/sync-dist.mjs",
    "prepack": "npm run check",
    "check": "node --check ./src/index.mjs && node --check ./src/rom-weaver-runtime-utils.mjs && node --check ./src/rom-weaver-zenfs-api.mjs && node --check ./src/workers/runner-worker-core.mjs && node --check ./src/workers/browser-runner-worker.mjs && node --check ./src/workers/worker-client-core.mjs && node --check ./src/workers/browser-worker-client.mjs && node --check ./src/workers/worker-protocol.mjs",
    "test": "npm run test:browser",
    "test:browser": "vitest --config ./vitest.browser.config.mjs run",
    "test:browser:stress:1gb": "ROM_WEAVER_WASM_STRESS_1GB=1 vitest --config ./vitest.browser.config.mjs run -t \"survives 1 GiB compress extract checksum and 100MB-class xdelta apply workload\""
  },
  "devDependencies": {
    "@bjorn3/browser_wasi_shim": "^0.4.2",
    "@vitest/browser": "^4.1.7",
    "@vitest/browser-playwright": "^4.1.7",
    "@zenfs/core": "^2.5.6",
    "@zenfs/dom": "^1.2.9",
    "playwright": "^1.60.0",
    "vitest": "^4.1.7"
  },
  "peerDependencies": {
    "@bjorn3/browser_wasi_shim": "^0.4.2",
    "@zenfs/core": "^2.5.6",
    "@zenfs/dom": "^1.2.9"
  },
  "peerDependenciesMeta": {
    "@bjorn3/browser_wasi_shim": {
      "optional": true
    },
    "@zenfs/core": {
      "optional": true
    },
    "@zenfs/dom": {
      "optional": true
    }
  }
}
