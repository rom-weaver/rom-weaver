{
  "name": "rom-weaver-wasm",
  "version": "0.1.0",
  "description": "JavaScript APIs and WASM artifacts for rom-weaver",
  "type": "module",
  "types": "./src/index.d.ts",
  "license": "MIT OR Apache-2.0",
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "files": [
    "src/",
    "rom-weaver-app.wasm",
    "rom-weaver-app.wasm.br",
    "README.md",
    "NOTICE",
    "THIRD_PARTY_LICENSES.md"
  ],
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.mjs"
    },
    "./browser-opfs": {
      "types": "./src/rom-weaver-browser-opfs-api.d.ts",
      "import": "./src/rom-weaver-browser-opfs-api.ts"
    },
    "./workers/browser-client": {
      "types": "./src/workers/browser-worker-client.d.ts",
      "import": "./src/workers/browser-worker-client.ts"
    },
    "./workers/protocol": {
      "types": "./src/workers/worker-protocol.d.ts",
      "import": "./src/workers/worker-protocol.ts"
    },
    "./workers/browser-runner-worker": {
      "types": "./src/workers/browser-runner-worker.d.ts",
      "import": "./src/workers/browser-runner-worker.ts"
    },
    "./workers/browser-wasi-thread-worker": {
      "import": "./src/workers/browser-wasi-thread-worker.ts"
    },
    "./rom-weaver-app.wasm": "./rom-weaver-app.wasm",
    "./rom-weaver-app.wasm.br": "./rom-weaver-app.wasm.br"
  },
  "scripts": {
    "prepare:dist": "node ./scripts/sync-dist.mjs",
    "prepack": "npm run check",
    "check": "npm run check:types && node --check ./src/index.mjs",
    "check:types": "tsc -p tsconfig.json --noEmit",
    "check:opfs-api-sync": "node ./scripts/check-opfs-api-sync.mjs",
    "test": "npm run test:browser",
    "test:browser": "vitest --config ./vitest.browser.config.mjs run",
    "test:browser:bench": "ROM_WEAVER_WASM_BENCH=1 vitest --config ./vitest.browser.config.mjs bench",
    "test:browser:bench:command-paths": "ROM_WEAVER_WASM_BENCH=1 vitest --config ./vitest.browser.config.mjs bench tests/browser-worker-client.bench.mjs",
    "test:browser:bench:checksum-threading": "ROM_WEAVER_WASM_BENCH=1 vitest --config ./vitest.browser.config.mjs bench tests/browser-checksum-threading.bench.mjs",
    "test:browser:stress:1gb": "ROM_WEAVER_WASM_STRESS_1GB=1 vitest --config ./vitest.browser.config.mjs run -t \"survives 1 GiB compress extract checksum and 100MB-class xdelta apply workload\""
  },
  "devDependencies": {
    "@bjorn3/browser_wasi_shim": "^0.4.2",
    "@vitest/browser": "^4.1.7",
    "@vitest/browser-playwright": "^4.1.7",
    "playwright": "^1.60.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "peerDependencies": {
    "@bjorn3/browser_wasi_shim": "^0.4.2"
  },
  "peerDependenciesMeta": {
    "@bjorn3/browser_wasi_shim": {
      "optional": true
    }
  }
}
