{
  "name": "rom-weaver-wasm",
  "version": "0.1.0",
  "description": "JavaScript APIs and WASM artifacts for rom-weaver",
  "type": "module",
  "types": "./src/index.d.ts",
  "license": "MIT OR Apache-2.0",
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "files": [
    "src/",
    "rom-weaver-cli.wasm",
    "rom-weaver-cli.wasm.br",
    "rom-weaver-cli-threaded.wasm",
    "rom-weaver-cli-threaded.wasm.br",
    "threaded.args",
    "README.md",
    "NOTICE",
    "THIRD_PARTY_LICENSES.md"
  ],
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.mjs"
    },
    "./node": {
      "types": "./src/rom-weaver-wasi-api.d.ts",
      "import": "./src/rom-weaver-wasi-api.mjs"
    },
    "./zenfs": {
      "types": "./src/rom-weaver-zenfs-api.d.ts",
      "import": "./src/rom-weaver-zenfs-api.mjs"
    },
    "./workers/node-client": {
      "types": "./src/workers/node-worker-client.d.ts",
      "import": "./src/workers/node-worker-client.mjs"
    },
    "./workers/browser-client": {
      "types": "./src/workers/browser-worker-client.d.ts",
      "import": "./src/workers/browser-worker-client.mjs"
    },
    "./workers/protocol": {
      "types": "./src/workers/worker-protocol.d.ts",
      "import": "./src/workers/worker-protocol.mjs"
    },
    "./workers/node-runner-worker": {
      "types": "./src/workers/node-runner-worker.d.ts",
      "import": "./src/workers/node-runner-worker.mjs"
    },
    "./workers/browser-runner-worker": {
      "types": "./src/workers/browser-runner-worker.d.ts",
      "import": "./src/workers/browser-runner-worker.mjs"
    },
    "./rom-weaver-cli.wasm": "./rom-weaver-cli.wasm",
    "./rom-weaver-cli.wasm.br": "./rom-weaver-cli.wasm.br",
    "./rom-weaver-cli-threaded.wasm": "./rom-weaver-cli-threaded.wasm",
    "./rom-weaver-cli-threaded.wasm.br": "./rom-weaver-cli-threaded.wasm.br",
    "./threaded.args": "./threaded.args"
  },
  "scripts": {
    "prepare:dist": "node ./scripts/sync-dist.mjs",
    "prepack": "npm run prepare:dist",
    "check": "node --check ./src/index.mjs && node --check ./src/rom-weaver-wasi-api.mjs && node --check ./src/rom-weaver-zenfs-api.mjs && node --check ./src/workers/runner-worker-core.mjs && node --check ./src/workers/node-runner-worker.mjs && node --check ./src/workers/browser-runner-worker.mjs && node --check ./src/workers/worker-client-core.mjs && node --check ./src/workers/node-worker-client.mjs && node --check ./src/workers/browser-worker-client.mjs && node --check ./src/workers/worker-protocol.mjs",
    "test": "node --test ./tests/*.test.mjs"
  },
  "peerDependencies": {
    "@bjorn3/browser_wasi_shim": "^0.4.2",
    "@zenfs/core": "^2.5.6",
    "@zenfs/dom": "^2.5.6"
  },
  "peerDependenciesMeta": {
    "@bjorn3/browser_wasi_shim": {
      "optional": true
    },
    "@zenfs/core": {
      "optional": true
    },
    "@zenfs/dom": {
      "optional": true
    }
  }
}
