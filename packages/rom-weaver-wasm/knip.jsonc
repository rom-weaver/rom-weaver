{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/browser-format-matrix.ts",
    "tests/*.test.mjs",
    "tests/*.bench.mjs"
  ],
  "project": [
    "src/**/*.{js,mjs,cjs,jsx,ts,tsx,mts,cts}",
    "tests/**/*.{js,mjs,cjs,jsx,ts,tsx,mts,cts}",
    "scripts/**/*.mjs",
    "*.mjs"
  ],
  "ignoreDependencies": ["@vitest/browser"],
  "rules": {
    "exports": "off",
    "types": "off"
  }
}
