{
  "name": "rom-weaver-react",
  "version": "0.1.0",
  "description": "RomWeaver patcher-only webapp and React API",
  "type": "module",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "types": "./src/index.tsx",
      "import": "./src/index.tsx"
    },
    "./webapp": "./src/webapp/main.tsx"
  },
  "overrides": {
    "vite-plugin-pwa": {
      "vite": "$vite"
    }
  },
  "scripts": {
    "dev": "node scripts/dev-server.mjs",
    "build": "vite build",
    "preview": "node scripts/dev-server.mjs preview",
    "lint": "npm run lint:i18n && npm run lint:code && npm run lint:types && npm run lint:browser-compat && npm run lint:knip && npm run audit:strings",
    "lint:browser-compat": "node scripts/check-browser-compat.mjs",
    "lint:code": "biome check package.json index.html vite.config.mjs vitest.config.base.mjs vitest.browser.config.mjs vitest.unit.config.mjs vitest.wasm.browser.config.mjs tsconfig.base.json tsconfig.json src tests --diagnostic-level=error",
    "lint:i18n": "lingui compile --strict --typescript",
    "lint:knip": "knip --no-progress",
    "i18n:extract": "lingui extract",
    "i18n:compile": "lingui compile --typescript",
    "lint:types": "tsc -p tsconfig.json --noEmit",
    "prepare:dist": "node ./scripts/sync-dist.mjs",
    "test": "npm run test:browser",
    "test:unit": "vitest --config ./vitest.unit.config.mjs run",
    "test:browser": "vitest --config ./vitest.browser.config.mjs run",
    "test:browser:coverage": "ROM_WEAVER_COVERAGE=1 vitest --config ./vitest.browser.config.mjs run --coverage",
    "test:browser:parallel": "node scripts/run-browser-tests.mjs",
    "test:browser:chromium": "ROM_WEAVER_BROWSER=chromium vitest --config ./vitest.browser.config.mjs run",
    "test:browser:wasm": "vitest --config ./vitest.wasm.browser.config.mjs run",
    "test:browser:wasm:coverage": "ROM_WEAVER_COVERAGE=1 vitest --config ./vitest.wasm.browser.config.mjs run --coverage",
    "test:browser:wasm:bench": "ROM_WEAVER_WASM_BENCH=1 vitest --config ./vitest.wasm.browser.config.mjs bench",
    "test:browser:wasm:bench:checksum-threading": "ROM_WEAVER_WASM_BENCH=1 vitest --config ./vitest.wasm.browser.config.mjs bench tests/wasm/browser-checksum-threading.bench.mjs",
    "test:browser:wasm:bench:command-paths": "ROM_WEAVER_WASM_BENCH=1 vitest --config ./vitest.wasm.browser.config.mjs bench tests/wasm/browser-worker-client.bench.mjs",
    "test:browser:wasm:stress:1gb": "ROM_WEAVER_WASM_STRESS_1GB=1 vitest --config ./vitest.wasm.browser.config.mjs run -t \"survives 1 GiB compress extract checksum and 100MB-class xdelta apply workload\"",
    "test:browser:webkit": "ROM_WEAVER_BROWSER=webkit vitest --config ./vitest.browser.config.mjs run",
    "test:browser:webkit:smoke": "ROM_WEAVER_BROWSER=webkit vitest --config ./vitest.browser.config.mjs run tests/browser/mobile-safari-runtime-smoke.browser.test.js",
    "verify:sw:no-coop-coep": "node scripts/verify-service-worker-no-coop-coep.mjs",
    "audit:strings": "if rg --hidden --glob '!node_modules/**' --glob '!.git/**' --glob '!dist/**' 'rom-patcher' src tests index.html; then echo 'Found legacy rom-patcher identifiers' && exit 1; else echo 'No legacy rom-patcher identifiers found'; fi"
  },
  "dependencies": {
    "@bjorn3/browser_wasi_shim": "0.4.2",
    "@lingui/core": "6.4.0",
    "lucide-react": "0.554.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "valibot": "1.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@lingui/babel-plugin-lingui-macro": "6.4.0",
    "@lingui/cli": "6.4.0",
    "@lingui/conf": "6.4.0",
    "@lingui/format-po": "6.4.0",
    "@mdn/browser-compat-data": "8.0.0",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/browser": "4.1.7",
    "@vitest/browser-playwright": "4.1.7",
    "@vitest/coverage-v8": "4.1.7",
    "axe-core": "4.12.1",
    "browserslist": "4.28.2",
    "happy-dom": "20.10.2",
    "knip": "6.16.1",
    "playwright": "1.60.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.0",
    "vite-plugin-pwa": "1.2.0",
    "vitest": "4.1.7",
    "workbox-core": "7.4.0",
    "workbox-precaching": "7.4.0",
    "workbox-routing": "7.4.0"
  },
  "browserslist": [
    "last 2 Chrome major versions",
    "last 2 Edge major versions",
    "last 2 Firefox major versions",
    "last 2 Safari major versions",
    "last 2 iOS major versions"
  ]
}
