{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "checkJs": false,
    "lib": ["dom", "dom.iterable", "webworker", "esnext"],
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "types": ["vite/client", "node"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.d.ts"
  ]
}
